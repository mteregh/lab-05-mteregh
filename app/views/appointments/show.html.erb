<h1>Appointment Details</h1>

<p><strong>Date:</strong> <%= @appointment.date %></p>
<p><strong>Reason:</strong> <%= @appointment.reason %></p>
<p><strong>Status:</strong> <%= @appointment.status %></p>
<p>
  <strong>Pet:</strong>
  <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %>
</p>
<p>
  <strong>Vet:</strong>
  <%= link_to @appointment.vet.full_name, vet_path(@appointment.vet) %>
</p>

<h2>Treatments</h2>

<ul>
  <% @appointment.treatments.each do |treatment| %>
    <li>
      <strong>Name:</strong> <%= treatment.name %><br>
      <strong>Medication:</strong> <%= treatment.medication %><br>
      <strong>Dosage:</strong> <%= treatment.dosage %><br>
      <strong>Administered at:</strong> <%= treatment.administered_at %><br>
      <strong>Notes:</strong> <%= treatment.notes %>
    </li>
    <br>
  <% end %>
</ul>