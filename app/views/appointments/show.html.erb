<h1 class="mb-4">Appointment Details</h1>

<div class="card mb-4">
  <div class="card-body">
    <p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y %I:%M %p") %></p>
    <p><strong>Reason:</strong> <%= @appointment.reason %></p>
    <p><strong>Status:</strong> <%= @appointment.status.humanize %></p>
    <p><strong>Pet:</strong> <%= link_to @appointment.pet.name, pet_path(@appointment.pet) %></p>
    <p><strong>Vet:</strong> <%= link_to @appointment.vet.full_name, vet_path(@appointment.vet) %></p>
  </div>
</div>

<h2>Treatments</h2>

<% if @appointment.treatments.any? %>
  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Administered at</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% @appointment.treatments.each do |treatment| %>
        <tr>
          <td><%= treatment.name %></td>
          <td><%= treatment.medication %></td>
          <td><%= treatment.dosage %></td>
          <td><%= treatment.administered_at.strftime("%B %d, %Y %I:%M %p") %></td>
          <td><%= treatment.notes %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No treatments recorded for this appointment.</p>
  
<% end %>