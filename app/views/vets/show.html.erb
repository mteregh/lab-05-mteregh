<h1 class="mb-4"><%= @vet.full_name %></h1>

<div class="card mb-4">
  <div class="card-body">
    <p><strong>Email:</strong> <%= @vet.email %></p>
    <p><strong>Phone:</strong> <%= @vet.phone %></p>
    <p><strong>Specialization:</strong> <%= @vet.specialization %></p>
  </div>
</div>

<h2>Appointments</h2>
<ul class="list-group">
  <% @vet.appointments.each do |appointment| %>
    <li class="list-group-item">
      <%= link_to appointment.date.strftime("%B %d, %Y %I:%M %p"), appointment_path(appointment) %>
      - <%= appointment.pet.name %>
    </li>
  <% end %>
  
</ul>